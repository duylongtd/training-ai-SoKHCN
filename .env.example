# Copy file này thành .env.local rồi điền key thật
# .env.local KHÔNG được commit lên git (đã có trong .gitignore)
#
# Khi deploy Vercel: KHÔNG cần tạo .env.local trên server,
# vào Vercel Dashboard > Project > Settings > Environment Variables
# và thêm biến GEMINI_API_KEY ở đó.

GEMINI_API_KEY=AIzaSyB...your-key-here
